    .hrb{border-color:#d29922;color:#d29922}.hrb:hover{background:#2a2113}
    .hbl{border-color:#58a6ff;color:#58a6ff}.hbl:hover{background:#111d2e}
    .btn:disabled{opacity:.35;cursor:default;pointer-events:none}
